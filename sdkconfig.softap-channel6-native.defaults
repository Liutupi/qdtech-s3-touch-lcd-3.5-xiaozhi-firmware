# Hardware-gated QDTech native SoftAP channel-6 candidate.
# Keep only the intended first-provisioning behavior; all pure diagnostics off.
# CONFIG_QDTECH_PROVISIONING_COMPAT is not set
CONFIG_QDTECH_EXPERIMENT_FAST_PROVISIONING_FALLBACK=y
CONFIG_QDTECH_EXPERIMENT_NETWORK_FIRST_BOOT=y
CONFIG_QDTECH_EXPERIMENT_STATELESS_SOFTAP_RF=y
CONFIG_QDTECH_EXPERIMENT_SOFTAP_CHANNEL_6_AB=y
# CONFIG_QDTECH_EXPERIMENT_WIFI_RX_SELF_TEST is not set
# CONFIG_QDTECH_EXPERIMENT_WIFI_STA_TX_SELF_TEST is not set
# CONFIG_QDTECH_EXPERIMENT_SINGLE_DRIVER_APSTA_PROVISIONING is not set
# CONFIG_QDTECH_EXPERIMENT_RAW_BEACON_FALLBACK is not set
