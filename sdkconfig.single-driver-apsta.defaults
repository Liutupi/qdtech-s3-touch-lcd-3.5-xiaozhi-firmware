# Explicit opt-in profile for QDTech single-driver STA-to-APSTA provisioning.
# All experiment options remain default-off in Kconfig.
# CONFIG_QDTECH_PROVISIONING_COMPAT is not set
CONFIG_QDTECH_EXPERIMENT_FAST_PROVISIONING_FALLBACK=y
CONFIG_QDTECH_EXPERIMENT_NETWORK_FIRST_BOOT=y
CONFIG_QDTECH_EXPERIMENT_STATELESS_SOFTAP_RF=y
CONFIG_QDTECH_EXPERIMENT_WIFI_RX_SELF_TEST=y
CONFIG_QDTECH_EXPERIMENT_SINGLE_DRIVER_APSTA_PROVISIONING=y
